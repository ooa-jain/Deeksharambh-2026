[Unit]
Description=Deeksharambh 2026 — Flask Survey App
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/deeksharambh
EnvironmentFile=/var/www/deeksharambh/.env
ExecStart=/var/www/deeksharambh/venv/bin/gunicorn -c gunicorn.conf.py app:app
Restart=on-failure
RestartSec=5s
StandardOutput=journal
StandardError=journal
SyslogIdentifier=deeksharambh

[Install]
WantedBy=multi-user.target
